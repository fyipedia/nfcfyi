{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.fyipedia/nfcfyi",
  "description": "NFC chip encyclopedia API client — look up NFC Forum types, NDEF records, operating modes, ISO",
  "version": "0.1.1",
  "repository": {
    "url": "https://github.com/fyipedia/nfcfyi",
    "source": "github"
  },
  "packages": [
    {
      "registryType": "pypi",
      "registryBaseUrl": "https://pypi.org",
      "identifier": "nfcfyi",
      "version": "0.1.1",
      "runtimeHint": "uvx",
      "transport": {
        "type": "stdio"
      },
      "runtimeArguments": [
        {
          "type": "named",
          "name": "--from",
          "value": "nfcfyi[mcp]"
        },
        {
          "type": "positional",
          "value": "python"
        },
        {
          "type": "positional",
          "value": "-m"
        },
        {
          "type": "positional",
          "value": "nfcfyi.mcp_server"
        }
      ]
    }
  ]
}
